# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Connect to running local postgres via Homebrew or standard Docker setup
DATABASE_URL=postgresql://mohit@localhost:5432/tenant_rag_db

# RAG & Embedding Config
# Options: local, openai, gemini
EMBEDDING_PROVIDER=local
# Options: local, openai, gemini
LLM_PROVIDER=local

# API Keys (Required if using openai or gemini providers)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# RAG Hyperparameters
SIMILARITY_THRESHOLD=0.65
CHUNK_SIZE=500
CHUNK_OVERLAP=100
